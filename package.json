{
  "name": "nuxt-app",
  "version": "0.5.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "prisma generate && nuxt build",
    "build:quiet": "prisma generate 2>/dev/null && nuxt build --log-level silent",
    "dev": "nuxt dev --host 127.0.0.1 --port 3000",
    "generate": "nuxt generate",
    "preview": "NITRO_HOST=127.0.0.1 NITRO_PORT=3001 nuxt preview",
    "pwa:icons": "node scripts/generate-pwa-icons.mjs",
    "postinstall": "nuxt prepare && prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:migrate:deploy": "prisma migrate deploy && prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push && prisma generate",
    "db:seed": "prisma db seed",
    "devData": "tsx scripts/dev-data.ts",
    "recomputeTimelineScores": "tsx scripts/recompute-timeline-scores.ts",
    "backfillEngagementAggregates": "tsx scripts/backfill-engagement-aggregates.ts",
    "srp:env": "tsx scripts/generate-srp-env.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bdd": "npm run test:bdd:quiet",
    "test:bdd:quiet": "dotenv --quiet -e .env -e .env.e2e -- ./scripts/run-bdd.sh quiet",
    "test:bdd:debug": "dotenv --quiet -e .env -e .env.e2e -- ./scripts/run-bdd.sh debug",
    "test:bdd:local": "dotenv --quiet -e .env -e .env.e2e -- cucumber-js \"features/**/*.feature\" --import \"features/**/*.js\" --format pretty --parallel 1 --tags \"not @pending\"",
    "test:bdd:remote": "dotenv --quiet -e .env.e2e -- cucumber-js \"features/**/*.feature\" --import \"features/**/*.js\" --format progress --parallel 1 --tags \"not @pending\"",
    "test:e2e": "dotenv --quiet -e .env -e .env.e2e -- sh -c 'kill $(lsof -ti:4275) 2>/dev/null || true; npm run build:quiet && npx start-server-and-test \"NITRO_HOST=127.0.0.1 NITRO_PORT=4275 node .output/server/index.mjs > /dev/null 2>&1\" http://127.0.0.1:4275/help \"playwright test\"'",
    "test:e2e:remote": "dotenv --quiet -e .env.e2e -- playwright test",
    "test:e2e:remote-smoke": "dotenv --quiet -e .env.e2e -- playwright test --config playwright.remote-smoke.config.ts",
    "check": "npm run lint -- --quiet && npm run test -- --reporter dot && npm run typecheck",
    "verify": "npm run lint && npm run test && npm run typecheck",
    "typecheck": "nuxi typecheck"
  },
  "dependencies": {
    "@cucumber/pretty-formatter": "^3.3.1",
    "@nuxtjs/i18n": "^10.4.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.0",
    "chart.js": "^4.5.1",
    "daisyui": "^5.5.20",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "jose": "^6.2.2",
    "marked": "^18.0.5",
    "nuxt": "^4.4.6",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.0",
    "tssrp6a": "^3.0.0",
    "vue": "^3.5.35",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@cucumber/cucumber": "^13.0.0",
    "@nuxt/eslint": "^1.15.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "@types/pg": "^8.15.0",
    "@vite-pwa/nuxt": "^1.1.1",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.11",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.4.1",
    "happy-dom": "^20.10.1",
    "jsdom": "^29.1.1",
    "sharp": "^0.34.5",
    "start-server-and-test": "^3.0.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "unplugin-auto-import": "^21.0.0",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.2"
  },
  "overrides": {
    "@hono/node-server": "^1.19.14",
    "hono": "^4.12.23"
  }
}
