{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "prisma generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "devData": "tsx scripts/dev-data.ts",
    "recomputeTimelineScores": "tsx scripts/recompute-timeline-scores.ts",
    "backfillEngagementAggregates": "tsx scripts/backfill-engagement-aggregates.ts",
    "srp:env": "tsx scripts/generate-srp-env.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "npm run lint && npm run test && npm run typecheck",
    "typecheck": "nuxi typecheck"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nuxt/content": "^3.12.0",
    "@nuxtjs/i18n": "^10.2.4",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@prisma/client": "^6.19.0",
    "@tailwindcss/typography": "^0.5.19",
    "chart.js": "^4.5.1",
    "daisyui": "^3",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "jose": "^6.2.2",
    "marked": "^12.0.2",
    "nuxt": "^3.21.0",
    "prisma": "^6.19.0",
    "tssrp6a": "^3.0.0",
    "vue": "^3.5.0",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@nuxt/eslint": "^1.15.0",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.15.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.19.3",
    "vitest": "^3.2.0"
  }
}
