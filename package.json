{
  "name": "nuxt-app",
  "version": "0.4.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "prisma generate && nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare && prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev && prisma generate",
    "db:migrate:deploy": "prisma migrate deploy && prisma generate",
    "db:studio": "prisma studio",
    "db:push": "prisma db push && prisma generate",
    "db:seed": "prisma db seed",
    "devData": "tsx scripts/dev-data.ts",
    "recomputeTimelineScores": "tsx scripts/recompute-timeline-scores.ts",
    "backfillEngagementAggregates": "tsx scripts/backfill-engagement-aggregates.ts",
    "srp:env": "tsx scripts/generate-srp-env.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:bdd": "dotenv -e .env -e .env.e2e -- sh -c 'npm run build && npx start-server-and-test \"NITRO_HOST=127.0.0.1 NITRO_PORT=4275 node .output/server/index.mjs\" http://127.0.0.1:4275/help \"cucumber-js \\\"features/**/*.feature\\\" --import \\\"features/**/*.js\\\" --format progress --parallel 1\"'",
    "test:bdd:local": "dotenv -e .env -e .env.e2e -- cucumber-js \"features/**/*.feature\" --import \"features/**/*.js\" --format progress --parallel 1",
    "test:e2e": "dotenv -e .env -e .env.e2e -- sh -c 'npm run build && npx start-server-and-test \"NITRO_HOST=127.0.0.1 NITRO_PORT=4275 node .output/server/index.mjs\" http://127.0.0.1:4275/help \"playwright test\"'",
    "verify": "npm run lint && npm run test && npm run typecheck",
    "typecheck": "nuxi typecheck"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^10.3.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.0",
    "chart.js": "^4.5.1",
    "daisyui": "^5.0.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.3",
    "dotenv": "^17.4.2",
    "jose": "^6.2.2",
    "marked": "^15.0.0",
    "nuxt": "^4.0.0",
    "pg": "^8.16.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.1.0",
    "tssrp6a": "^3.0.0",
    "vue": "^3.5.33",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^5.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@cucumber/cucumber": "^12.8.2",
    "@nuxt/eslint": "^1.15.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.8",
    "dotenv-cli": "^8.0.0",
    "eslint": "^10.0.0",
    "happy-dom": "^20.9.0",
    "start-server-and-test": "^3.0.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.0",
    "unplugin-auto-import": "^21.0.0",
    "vitest": "^4.0.0",
    "vue-tsc": "^3.2.0"
  }
}
