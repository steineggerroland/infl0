# Committed defaults for Playwright + `npm run test:e2e` (NOT production).
# With `npm run test:e2e`, dotenv-cli loads `.env` then this file (no `--override`).
# Duplicate keys keep values from `.env`; this file supplies defaults you did not set locally.
# Requires a running Postgres matching DATABASE_URL and `npx prisma db seed`
# so `dev@localhost` exists with SRP credentials below.
#
# Password for Playwright SRP login (must match verifier):
#   infl0-dev-e2e

DATABASE_URL=postgresql://infl0:change_me_strong_password@127.0.0.1:5432/infl0
AUTH_JWT_SECRET=infl0_e2e_jwt_secret_at_least_16

DEV_SEED_EMAIL=dev@localhost
DEV_SRP_SALT_HEX=4e2972528b6a46dd83211f366fee97283c499c1a4e3cb610eee398476d43dca7239768a16491a5d8ea85f77f9f24f4381a9c137f8d14aee4793f41ef09d574867bce808a9a2c283c0ee17fe4d3ad6fdf41e97d781f4e34d60e921be913875592ee7ecf74129a2454cb7b901a3a535ab0924b13fd09ada1202eb8948fbe8d3f37
DEV_SRP_VERIFIER_

E2E_LOGIN_EMAIL=dev@localhost
E2E_LOGIN_PASSWORD=infl0-dev-e2e

# Invite code used by the chromium-onboarding Playwright project to
# register fresh `regression-test-<unique>@neurospicy.icu` accounts
# per worker. The value is only meaningful when the server is run
# against this committed `.env.e2e`; production must override it
# with NUXT_REGISTRATION_INVITE_CODE in the deployment env.
NUXT_REGISTRATION_INVITE_CODE=infl0-e2e-invite

# Crawler ingest key for HTTP-only BDD article fixtures.
NUXT_CRAWLER_API_KEY=infl0-e2e-crawler

# Dedicated operator seed account for /operator/sources tests.
# Password:
#   operator
OPERATOR_SEED_EMAIL=operator@localhost
OPERATOR_SEED_NAME=Operator
OPERATOR_SRP_SALT_HEX=af96ff7393fc9983099e6969b2cf9d90d6207ce7ff7aa01b460ff94b72a41c4285abb5e26298f0098255a723984ae2431d60ef5ece44a09c0fd0a77d3dcd19e9fd3721474d52b6e66b84f35eaae1d19c6c8780909480630c873e49074116de47983c03fe57c5da46eef54e386704d1fdd5a10ce5afbea3e68eeec9bb22d66703
OPERATOR_SRP_VERIFIER_

# Operator area access for BDD / manual test runs.
NUXT_OPERATOR_EMAILS=operator@localhost
OPERATOR_LOGIN_EMAIL=operator@localhost
OPERATOR_LOGIN_PASSWORD=operator
