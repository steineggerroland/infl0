# docker-compose / App
POSTGRES_USER=infl0
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=infl0
# Port-Mapping nur auf Loopback; bei Konflikt mit lokalem Postgres z. B. 5433 setzen
POSTGRES_HOST_PORT=5432
APP_PORT=3000

# Prisma auf dem Mac: gleiches Passwort wie POSTGRES_PASSWORD, Host 127.0.0.1
DATABASE_URL=postgresql://infl0:change_me_strong_password@127.0.0.1:5432/infl0

# Shared secret: Header z. B. Authorization: Bearer <key> oder X-Crawler-Key
# → POST /api/crawler/ingest (JSON: crawlKey + Artikel-Felder wie vom Crawler)
NUXT_CRAWLER_API_KEY=

# prisma db seed (optional) — gleiche E-Mail steuert GET /api/timeline (Beta)
BETA_SEED_EMAIL=beta@localhost
BETA_SEED_NAME=Beta
