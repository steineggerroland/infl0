# docker-compose / App
POSTGRES_USER=infl0
# Avoid `$` in this value when using docker-compose.yml: Compose expands `$name` inside interpolated strings (WARN: variable "z" for `$z`).
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=infl0
# Port mapping on loopback only; if local Postgres conflicts, e.g. set 5433
POSTGRES_HOST_PORT=5432
APP_PORT=3000

# Prisma on host: same password as POSTGRES_PASSWORD, host 127.0.0.1
DATABASE_URL=postgresql://infl0:change_me_strong_password@127.0.0.1:5432/infl0

# Shared secret: header e.g. Authorization: Bearer <key> or X-Crawler-Key
# → POST /api/crawler/ingest (JSON: crawlKey + article fields from crawler)
# → POST /api/crawler/source-status (JSON: latest crawl/health snapshot per crawlKey; camelCase or snake_case)
NUXT_CRAWLER_API_KEY=

# Session cookie (HS256); min 16 chars; in production use a long random value
AUTH_JWT_SECRET=change_me_to_a_long_random_secret

# Registration (/register): same value must be entered as "Invite code"; empty = registration disabled
NUXT_REGISTRATION_INVITE_CODE=

# Operator area (/operator/sources): comma-separated email allowlist.
# - Match is `trim().toLowerCase()` against `users.email` (no DB role yet).
# - Empty or typo-only value ⇒ /operator/* denies every request (403).
# - Server logs the parsed count + invalid entries once at boot.
# See docs/OPERATOR.md for the access model and follow-ups.
# Example (test/local): NUXT_OPERATOR_EMAILS=dev@localhost,operator@localhost
NUXT_OPERATOR_EMAILS=

# prisma db seed — SRP: only salt/verifier in DB (plaintext password never on server)
# Generate (local): SRP_GEN_PASSWORD='…' npx tsx scripts/generate-srp-env.ts
BETA_SEED_EMAIL=beta@localhost
BETA_SEED_NAME=Beta
BETA_SRP_SALT_HEX=
BETA_SRP_VERIFIER_HEX=

# Standard local / Playwright user (committed `.env.e2e` uses password `dev`)
DEV_SEED_EMAIL=dev@localhost
DEV_SEED_NAME=Dev
DEV_SRP_SALT_HEX=
DEV_SRP_VERIFIER_HEX=

# Optional dedicated operator seed account (committed `.env.e2e` uses password `dev`)
OPERATOR_SEED_EMAIL=operator@localhost
OPERATOR_SEED_NAME=Operator
OPERATOR_SRP_SALT_HEX=
OPERATOR_SRP_VERIFIER_HEX=

# Playwright SRP login (same password you used for `DEV_SRP_*` generation)
E2E_LOGIN_EMAIL=dev@localhost
E2E_LOGIN_PASSWORD=

# Operator SRP login for E2E / manual operator testing
OPERATOR_LOGIN_EMAIL=operator@localhost
OPERATOR_LOGIN_PASSWORD=
